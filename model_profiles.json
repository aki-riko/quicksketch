{
  "_说明": "按模型匹配思考等级，并为所有受支持模型统一提供稳定上下文。value 是写入 config.toml 的真实值，text 是界面显示文本。",
  "defaultReasoningOptions": [
    { "value": "", "text": "(不设置)" },
    { "value": "low", "text": "low" },
    { "value": "medium", "text": "medium" },
    { "value": "high", "text": "high" },
    { "value": "xhigh", "text": "xhigh" }
  ],
  "reasoningLabels": {
    "low": "轻度",
    "medium": "中",
    "high": "高",
    "xhigh": "极高"
  },
  "stableContextPreset": {
    "menuText": "稳定上下文",
    "contextWindow": 258400,
    "autoCompactLimit": 245000,
    "toolOutputLimit": 6000,
    "maxContextWindow": 258400,
    "maxAutoCompactLimit": 245000
  },
  "profiles": [
    {
      "id": "gpt-5.5",
      "modelPattern": "^gpt-5\\.5$",
      "reasoningOptions": [
        { "value": "", "text": "(不设置)" },
        { "value": "low", "text": "low" },
        { "value": "medium", "text": "medium" },
        { "value": "high", "text": "high" },
        { "value": "xhigh", "text": "xhigh" }
      ]
    },
    {
      "id": "gpt-5.6",
      "modelPattern": "^gpt-5\\.6(?:-|$)",
      "reasoningOptions": [
        { "value": "low", "text": "轻度" },
        { "value": "medium", "text": "中" },
        { "value": "high", "text": "高" },
        { "value": "xhigh", "text": "极高" }
      ]
    }
  ]
}
